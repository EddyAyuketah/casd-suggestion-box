def build_chamber_lookup(df_lineview, df_ceid):
    """
    Build chamber UTP/Qualified lookup from LineView with proper fraction parsing
    """
    lookup = {}
    
    if df_lineview.empty:
        print("  [WARN] LineView is empty")
        return lookup
    
    # Find columns
    all_cols = list(df_lineview.columns)
    print("  LineView has {} columns total".format(len(all_cols)))
    
    utp_col = 'UTP' if 'UTP' in all_cols else None
    qual_col = 'QUALIFIED' if 'QUALIFIED' in all_cols else None
    tot_col = None
    
    # Look for total chamber column
    for col in all_cols:
        if 'TOT' in col.upper() and 'CHMB' in col.upper():
            tot_col = col
            break
    
    print("  Found columns -> UTP: '{}', QUALIFIED: '{}', TOT: '{}'".format(utp_col, qual_col, tot_col))
    
    def parse_fraction(value):
        """Parse fraction strings like '3/4', '8/8' into numerator and denominator"""
        if pd.isna(value) or value == '' or str(value).strip() == '':
            return 0, 0
        
        value_str = str(value).strip()
        if '/' in value_str:
            try:
                parts = value_str.split('/')
                if len(parts) == 2:
                    num = float(parts[0].strip())
                    den = float(parts[1].strip())
                    return num, den
            except:
                pass
        
        try:
            num = float(value_str)
            return num, num
        except:
            return 0, 0
    
    # Build lookup with validation
    processed_count = 0
    valid_data_count = 0
    
    for _, row in df_lineview.iterrows():
        ceid = str(row.get('CEID', ''))
        if not ceid or ceid == 'nan':
            continue
        
        processed_count += 1
        
        # Parse fractions
        utp_num, utp_den = parse_fraction(row.get(utp_col, '')) if utp_col else (0, 0)
        qual_num, qual_den = parse_fraction(row.get(qual_col, '')) if qual_col else (0, 0)
        
        # Determine total chambers
        tot = safe_num(row.get(tot_col, 0)) if tot_col else max(utp_den, qual_den)
        
        # Validate and correct data
        if tot > 0:
            # Ensure values don't exceed total
            utp_num = min(utp_num, tot)
            qual_num = min(qual_num, tot)
            # Note: UTP can be > QUAL if unqualified chambers are running
        
        if utp_num > 0 or qual_num > 0 or tot > 0:
            valid_data_count += 1
        
        fist = str(row.get('FIST', ''))
        operation = str(row.get('OPERATION', ''))
        desc = str(row.get('OPER_SHORT_DESC', ''))[:40]
        
        if ceid not in lookup:
            lookup[ceid] = {
                'utp': utp_num, 'qual': qual_num, 'tot': tot,
                'fist': fist, 'operation': operation, 'desc': desc
            }
        else:
            # Keep the record with the highest total chambers (most complete data)
            if tot > lookup[ceid]['tot']:
                lookup[ceid].update({
                    'utp': utp_num, 'qual': qual_num, 'tot': tot,
                    'fist': fist, 'operation': operation, 'desc': desc
                })
    
    print("  Processed {} rows, found {} with valid chamber data".format(processed_count, valid_data_count))
    
    # Validate data consistency
    validate_data_consistency(lookup)
    
    return lookup

def build_fist_lookup(df_lineview):
