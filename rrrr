def analyze_trends(df_ceid):
    """Analyze performance trends with multiple time periods"""
    trends = {}
    
    for _, row in df_ceid.iterrows():
        ceid = str(row.get('CEID', ''))
        current_pace = safe_num(row.get('CW_WSPW_PACE', 0))
        prev_pace = safe_num(row.get('PS_WSPW_PACE', 0))
        
        # Calculate trend
        trend_pct = 0
        direction = 'stable'
        
        if prev_pace > 0 and current_pace > 0:
            trend_pct = ((current_pace - prev_pace) / prev_pace) * 100
            
            if trend_pct > THRESHOLDS['trend_improve']:
                direction = 'improving'
            elif trend_pct < THRESHOLDS['trend_decline']:
                direction = 'declining'
            else:
                direction = 'stable'
        
        trends[ceid] = {
            'current': current_pace,
            'previous': prev_pace,
            'trend_pct': trend_pct,
            'direction': direction,
            'velocity': abs(trend_pct) if trend_pct != 0 else 0
        }
    
    return trends

def identify_bottlenecks(df_ceid, chamber_lookup):
    """Comprehensive bottleneck analysis"""
    bottlenecks = []
    
    for _, row in df_ceid.iterrows():
        ceid = str(row.get('CEID', ''))
        pace = safe_num(row.get('CW_WSPW_PACE', 0))
        roads = safe_num(row.get('ROADS', 0))
        layer_count = safe_num(row.get('LAYER_COUNT', 0))
        
        chamber_data = chamber_lookup.get(ceid, {})
        utp = chamber_data.get('utp', 0)
        tot = chamber_data.get('tot', 0)
        
        # Calculate comprehensive bottleneck score
        bottleneck_score = 0
        factors = []
        
        # Factor 1: Capacity constraint (40% weight)
        if pace < CAPACITY_GOAL:
            capacity_impact = ((CAPACITY_GOAL - pace) / CAPACITY_GOAL) * 40
            bottleneck_score += capacity_impact
            factors.append("Capacity Gap: {:.0f}".format(CAPACITY_GOAL - pace))
        
        # Factor 2: Layer criticality (25% weight)
        if layer_count > THRESHOLDS['layer_count_min']:
            layer_impact = min(layer_count * 25, 25)
            bottleneck_score += layer_impact
            factors.append("High Layer Count: {:.2f}".format(layer_count))
        
        # Factor 3: Performance gap (25% weight)
        if roads > 0 and pace < roads * THRESHOLDS['performance_gap']:
            perf_gap = ((roads * THRESHOLDS['performance_gap']) - pace) / roads * 25
            bottleneck_score += perf_gap
            factors.append("Performance Gap: {:.1f}%".format(((roads - pace) / roads) * 100))
        
        # Factor 4: Chamber utilization (10% weight)
        if tot > 0:
            util_ratio = utp / tot
            if util_ratio < THRESHOLDS['chamber_util_min']:
                util_impact = (THRESHOLDS['chamber_util_min'] - util_ratio) * 10
                bottleneck_score += util_impact
                factors.append("Low Utilization: {:.0f}%".format(util_ratio * 100))
        
        if bottleneck_score >= THRESHOLDS['bottleneck_score']:
            bottlenecks.append({
                'ceid': ceid,
                'score': round(bottleneck_score, 1),
                'pace': pace,
                'roads': roads,
                'layer_count': layer_count,
                'factors': factors,
                'fist': chamber_data.get('fist', ''),
                'priority': 'Critical' if bottleneck_score > 50 else 'High' if bottleneck_score > 35 else 'Medium'
            })
    
    return sorted(bottlenecks, key=lambda x: x['score'], reverse=True)

def calc_health_score(utp, tot, qual, pace, roads, inv_ratio=1.0):
    """
    Calculate comprehensive health score with proper weighting
    """
    score = 0
    components = {}
    
    # Component 1: Tool Availability (UTP/Total)
    if tot > 0:
        availability = min(1.0, utp / tot)
        availability_score = availability * HEALTH_WEIGHTS['availability']
        score += availability_score
        components['availability'] = {
            'score': availability_score,
            'ratio': availability,
            'raw': "{}/{}".format(int(utp), int(tot))
        }
    
    # Component 2: Tool Qualification (Qualified/Total)
    if tot > 0:
        qualification = min(1.0, qual / tot)
        qualification_score = qualification * HEALTH_WEIGHTS['qualification']
        score += qualification_score
        components['qualification'] = {
            'score': qualification_score,
            'ratio': qualification,
            'raw': "{}/{}".format(int(qual), int(tot))
        }
    
    # Component 3: Performance vs Capability (Pace/ROADS)
    if roads > 0:
        performance = min(1.0, pace / roads)
        performance_score = performance * HEALTH_WEIGHTS['performance']
        score += performance_score
        components['performance'] = {
            'score': performance_score,
            'ratio': performance,
            'raw': "{:.0f}/{:.0f}".format(pace, roads)
        }
    
    # Component 4: Inventory Health (optimal = 1.0)
    inv_health = max(0, 1 - abs(inv_ratio - 1.0))
    inv_score = inv_health * HEALTH_WEIGHTS['inventory']
    score += inv_score
    components['inventory'] = {
        'score': inv_score,
        'ratio': inv_health,
        'raw': "{:.1f}".format(inv_ratio)
    }
    
    return round(score, 1), components

def health_class(score):
    """Determine health class based on score"""
    if score >= THRESHOLDS['health_warning']:
        return "health-good"
    elif score >= THRESHOLDS['health_critical']:
        return "health-warn"
    return "health-crit"

def generate_advanced_alerts(df_ceid, chamber_lookup, trends, bottlenecks):
    """Generate sophisticated predictive alerts with priority scoring"""
    alerts = []
    
    # Convert bottlenecks to dict for quick lookup
    bottleneck_dict = {b['ceid']: b for b in bottlenecks}
    
    for _, row in df_ceid.iterrows():
        ceid = str(row.get('CEID', ''))
        pace = safe_num(row.get('CW_WSPW_PACE', 0))
        roads = safe_num(row.get('ROADS', 0))
        layer_count = safe_num(row.get('LAYER_COUNT', 0))
        
        chamber_data = chamber_lookup.get(ceid, {})
        utp = chamber_data.get('utp', 0)
        tot = chamber_data.get('tot', 0)
        qual = chamber_data.get('qual', 0)
        
        reasons = []
        priority_score = 0
        
        # Alert 1: Declining trend
        if ceid in trends:
            trend_data = trends[ceid]
            if trend_data['direction'] == 'declining':
                reasons.append("Declining trend: {}".format(fmt_pct(trend_data['trend_pct'])))
                priority_score += abs(trend_data['trend_pct']) * 0.5
        
        # Alert 2: Low chamber utilization
        if tot > 0:
            util_ratio = utp / tot
            if util_ratio < THRESHOLDS['chamber_util_min']:
                reasons.append("Low chamber utilization: {}/{} ({:.0f}%)".format(
                    int(utp), int(tot), util_ratio * 100))
                priority_score += (THRESHOLDS['chamber_util_min'] - util_ratio) * 50
        
        # Alert 3: Performance degradation
        if roads > 0:
            perf_ratio = pace / roads
            if perf_ratio < 0.85:
                gap_pct = ((roads - pace) / roads) * 100
                reasons.append("Performance gap: {:.0f}% below ROADS".format(gap_pct))
                priority_score += gap_pct * 0.3
        
        # Alert 4: Critical tool at risk
        if layer_count > THRESHOLDS['layer_count_min'] and pace < CAPACITY_GOAL * 0.9:
            reasons.append("Critical tool at risk (Layer Count: {:.2f})".format(layer_count))
            priority_score += layer_count * 30
        
        # Alert 5: Bottleneck identification
        if ceid in bottleneck_dict:
            bottleneck = bottleneck_dict[ceid]
            reasons.append("Identified bottleneck (Score: {:.1f})".format(bottleneck['score']))
            priority_score += bottleneck['score']
        
        # Alert 6: Health score critical
        health_score, _ = calc_health_score(utp, tot, qual, pace, roads)
        if health_score < THRESHOLDS['health_critical']:
            reasons.append("Critical health score: {:.1f}".format(health_score))
            priority_score += (THRESHOLDS['health_critical'] - health_score)
        
        if reasons:
            # Determine alert level
            if priority_score > 75:
                alert_level = 'Critical'
            elif priority_score > 50:
                alert_level = 'High'
            elif priority_score > 25:
                alert_level = 'Medium'
            else:
                alert_level = 'Low'
            
            alerts.append({
                'ceid': ceid,
                'reasons': reasons,
                'priority_score': round(priority_score, 1),
                'alert_level': alert_level,
                'fist': chamber_data.get('fist', ''),
                'pace': pace,
                'roads': roads,
                'health_score': health_score
            })
    
    return sorted(alerts, key=lambda x: x['priority_score'], reverse=True)[:20]  # Top 20 alerts

