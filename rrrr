def build_search_index(df_ceid, df_lineview, chamber_lookup):
    """Build comprehensive search index for all CEIDs"""
    search_index = {}
    
    # Process CEID data
    if not df_ceid.empty:
        for _, row in df_ceid.iterrows():
            ceid = str(row.get('CEID', ''))
            if ceid and ceid != 'nan':
                search_index[ceid] = {
                    'ceid': ceid,
                    'operation': str(row.get('OPERATION', '')),
                    'pace': safe_num(row.get('CW_WSPW_PACE', 0)),
                    'roads': safe_num(row.get('ROADS', 0)),
                    'layer_count': safe_num(row.get('LAYER_COUNT', 0)),
                    'prev_pace': safe_num(row.get('PS_WSPW_PACE', 0)),
                    'source': 'CEID'
                }
    
    # Enhance with LineView data
    if not df_lineview.empty:
        for _, row in df_lineview.iterrows():
            ceid = str(row.get('CEID', ''))
            if ceid and ceid != 'nan':
                if ceid not in search_index:
                    search_index[ceid] = {
                        'ceid': ceid,
                        'operation': '',
                        'pace': 0,
                        'roads': 0,
                        'layer_count': 0,
                        'prev_pace': 0,
                        'source': 'LineView'
                    }
                
                # Add LineView specific data
                search_index[ceid].update({
                    'fist': str(row.get('FIST', '')),
                    'desc': str(row.get('OPER_SHORT_DESC', ''))[:50],
                    'inv_prod': safe_num(row.get('INV_PROD', 0)),
                    'inv_goal': safe_num(row.get('INV_GOAL', 0))
                })
    
    # Add chamber data
    for ceid, data in chamber_lookup.items():
        if ceid in search_index:
            search_index[ceid].update({
                'utp': data.get('utp', 0),
                'qual': data.get('qual', 0),
                'tot': data.get('tot', 0)
            })
    
    return search_index

def search_ceid(search_term, search_index):
    """Search for CEID and return detailed information"""
    search_term = str(search_term).strip().upper()
    
    if not search_term:
        return None
    
    # Direct match
    if search_term in search_index:
        return search_index[search_term]
    
    # Partial matches
    matches = []
    for ceid, data in search_index.items():
        if (search_term in ceid.upper() or 
            search_term in data.get('operation', '').upper() or
            search_term in data.get('fist', '').upper() or
            search_term in data.get('desc', '').upper()):
            matches.append(data)
    
    return matches if matches else None

