def safe_num(value, default=0):
    try:
        if pd.isna(value):
            return default
        result = pd.to_numeric(value, errors='coerce')
        return default if pd.isna(result) else float(result)
    except:
        return default

def fmt(value):
    try:
        return "{:,.0f}".format(float(value))
    except:
        return str(value)

def fmt_pct(value):
    try:
        return "{:+.1f}%".format(float(value))
    except:
        return "0.0%"

