def validate_data_consistency(chamber_lookup):
    """Validate data consistency across sources"""
    issues = []
    valid_count = 0
    
    for ceid, data in chamber_lookup.items():
        utp, qual, tot = data['utp'], data['qual'], data['tot']
        
        # Check logical consistency
        if utp > tot and tot > 0:
            issues.append("CEID {}: UTP ({}) > Total ({})".format(ceid, utp, tot))
        elif qual > tot and tot > 0:
            issues.append("CEID {}: QUAL ({}) > Total ({})".format(ceid, qual, tot))
        elif utp > qual and qual > 0:
            # This is actually valid - UTP can be > QUAL if unqualified chambers are up
            pass
        else:
            valid_count += 1
    
    print("  Data validation: {} valid, {} issues found".format(valid_count, len(issues)))
    if issues:
        print("  Sample issues:")
        for issue in issues[:5]:
            print("    - {}".format(issue))
    
    return issues

