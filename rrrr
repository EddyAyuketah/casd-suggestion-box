def process_ceid_data(df_ceid, chamber_lookup, fist_lookup, selected_fist):
    if df_ceid.empty:
        return pd.DataFrame(), pd.DataFrame(), pd.DataFrame()
    
    df = df_ceid.copy()
    
    # Ensure numeric columns
    numeric_cols = ['CW_WSPW_PACE', 'ROADS', 'LAYER_COUNT', 'CS_WSPW_PACE', 'PS_WSPW_PACE']
    for col in numeric_cols:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors='coerce').fillna(0)
    
    # Add chamber and FIST data
    df['FIST'] = df['CEID'].astype(str).map(fist_lookup).fillna('')
    df['UTP'] = df['CEID'].astype(str).apply(lambda x: chamber_lookup.get(x, {}).get('utp', 0))
    df['TOT_CHMB'] = df['CEID'].astype(str).apply(lambda x: chamber_lookup.get(x, {}).get('tot', 0))
    df['QUAL_CHMB'] = df['CEID'].astype(str).apply(lambda x: chamber_lookup.get(x, {}).get('qual', 0))
    df['OPER_DESC'] = df['CEID'].astype(str).apply(lambda x: chamber_lookup.get(x, {}).get('desc', ''))
    df['LV_OP'] = df['CEID'].astype(str).apply(lambda x: chamber_lookup.get(x, {}).get('operation', ''))
    
    if 'OPERATION' not in df.columns:
        df['OPERATION'] = df['LV_OP']
    
    # Apply filters
    if selected_fist:
        df = df[df['FIST'].isin(selected_fist)]
    
    if 'LAYER_COUNT' in df.columns:
        df = df[df['LAYER_COUNT'] >= THRESHOLDS['layer_count_min']]
    
    print("  After filters: {} CEIDs".format(len(df)))
    
    # Capacity constrained: tools below goal
    capacity = df[df['CW_WSPW_PACE'] < CAPACITY_GOAL].copy()
    capacity = capacity.sort_values('CW_WSPW_PACE', ascending=True)
    
    # Need max capacity: tools with ROADS below goal (potential for improvement)
    need_max = df[df['ROADS'] <= CAPACITY_GOAL].copy()
    
    # Performance gap: tools not meeting their potential
    perf_gap = df[
        (df['ROADS'] > 0) &
        (df['CW_WSPW_PACE'] < df['ROADS'] * THRESHOLDS['performance_gap'])
    ].copy()
    
    if not perf_gap.empty:
        perf_gap['GAP_PCT'] = ((perf_gap['ROADS'] - perf_gap['CW_WSPW_PACE']) / perf_gap['ROADS']) * 100
        perf_gap = perf_gap.sort_values('GAP_PCT', ascending=False)
    
    return capacity, need_max, perf_gap

def process_inventory_alerts(df_lineview, need_max_ceids, selected_fist):
    if df_lineview.empty:
        return pd.DataFrame()
    
    df = df_lineview.copy()
    
    if 'FIST' in df.columns and selected_fist:
        df = df[df['FIST'].isin(selected_fist)]
    
    # Ensure numeric columns
    for col in ['INV_PROD', 'INV_GOAL']:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors='coerce').fillna(0)
    
    if 'INV_PROD' in df.columns and 'INV_GOAL' in df.columns:
        df['INV_RATIO'] = df.apply(
            lambda r: r['INV_PROD'] / r['INV_GOAL'] if r['INV_GOAL'] > 0 else 0, axis=1
        )
        
        # Enhanced inventory logic: high inventory AND (low ROADS OR in need_max list)
        alerts = df[
            (df['INV_RATIO'] > THRESHOLDS['inv_over_goal']) &
            ((df['CEID'].isin(need_max_ceids)) | (df['INV_RATIO'] > 1.5))  # Very high inventory
        ].copy()
        
        return alerts.sort_values('INV_RATIO', ascending=False)
    
    return pd.DataFrame()

def process_down_entities(df_tool, alert_ceids):
    if df_tool.empty:
        return pd.DataFrame()
    
    df = df_tool.copy()
    
    if 'CEID' in df.columns and alert_ceids:
        df = df[df['CEID'].isin(alert_ceids)]
    
    if 'ENTITY_UTP' in df.columns:
        df['ENTITY_UTP'] = pd.to_numeric(df['ENTITY_UTP'], errors='coerce').fillna(0)
        down = df[df['ENTITY_UTP'] == 0].copy()
        if not down.empty:
            down = down.sort_values(['CEID', 'ENTITY'] if 'ENTITY' in down.columns else ['CEID'])
        return down
    
    return pd.DataFrame()

