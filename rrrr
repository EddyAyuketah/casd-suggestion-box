def should_update_baseline(now, existing_baseline):
    """Determine if we should update the baseline - FIXED VERSION"""
    # EXPANDED Update window: 5:30am - 6:30am (was 5:45-6:15)
    in_update_window = (now.hour == 5 and now.minute >= 30) or (now.hour == 6 and now.minute <= 30)
    
    print(f"[DEBUG] should_update_baseline check:")
    print(f"        now.hour={now.hour}, now.minute={now.minute}")
    print(f"        in_update_window={in_update_window}")
    
    if not in_update_window:
        # ADDED: Check if baseline is stale (from a previous day) - force update
        if existing_baseline:
            try:
                baseline_date = datetime.strptime(existing_baseline['date'], "%Y-%m-%d").date()
                today_6am = now.replace(hour=6, minute=0, second=0, microsecond=0)
                if now.hour < 6:
                    expected_baseline_date = (today_6am - timedelta(days=1)).date()
                else:
                    expected_baseline_date = today_6am.date()
                
                if baseline_date < expected_baseline_date:
                    print(f"[WARNING] Baseline is STALE: {baseline_date} < expected {expected_baseline_date}")
                    print(f"[WARNING] Forcing baseline update even outside normal window!")
                    return True
            except Exception as e:
                print(f"[DEBUG] Could not check baseline staleness: {e}")
        return False
    
    if not existing_baseline:
        print(f"[DEBUG] No existing baseline, will update")
        return True
    
    try:
        baseline_date = datetime.strptime(existing_baseline['date'], "%Y-%m-%d").date()
        today = now.date()
        
        print(f"[DEBUG] baseline_date={baseline_date}, today={today}")
        
        if baseline_date < today:
            print(f"[DEBUG] Baseline is from previous day, will update")
            return True
    except Exception as e:
        print(f"[DEBUG] Exception parsing baseline date: {e}, will update")
        return True
    
    print(f"[DEBUG] Baseline is current, no update needed")
    return False

