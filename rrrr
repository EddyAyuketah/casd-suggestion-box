def load_tsv(path, name="Data"):
    try:
        p = Path(path)
        if not p.exists():
            print("[WARN] {} not found".format(name))
            return pd.DataFrame()
        age = (datetime.now() - datetime.fromtimestamp(p.stat().st_mtime)).total_seconds() / 3600
        df = pd.read_csv(path, sep="\t", low_memory=False)
        print("[OK] {}: {} rows ({:.1f}h old)".format(name, len(df), age))
        return df
    except Exception as e:
        print("[ERR] {}: {}".format(name, e))
        return pd.DataFrame()

def load_comments():
    """Load comments from JSON file"""
    try:
        p = Path(COMMENTS_JSON_PATH)
        if p.exists():
            with open(p, 'r', encoding='utf-8') as f:
                data = json.load(f)
                print("[OK] Comments loaded: {} entries".format(len(data)))
                return data
    except Exception as e:
        print("[WARN] Comments load: {}".format(e))
    return {}

