        pace = safe_num(r.get('CW_WSPW_PACE', 0))
        roads = safe_num(r.get('ROADS', 0))
        gap = max(0, CAPACITY_GOAL - pace)  # Fixed: only positive gaps
        fist = str(r.get('FIST', ''))
        
        utp = safe_num(r.get('UTP', 0))
        tot = safe_num(r.get('TOT_CHMB', 0))
        qual = safe_num(r.get('QUAL_CHMB', 0))
        
